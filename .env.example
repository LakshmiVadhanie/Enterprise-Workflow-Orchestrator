# Copy this to .env and fill in your values
# DO NOT commit .env to git

# Database
POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow_secret
POSTGRES_DB=workflow_db

# Secrets
JWT_SECRET=change-me-in-production-use-256-bit-random-string
DJANGO_SECRET_KEY=change-me-in-production

# GCP (for Kubernetes deployment)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_CLUSTER_NAME=workflow-cluster
GCP_REGISTRY=gcr.io/your-gcp-project-id

# Service URLs (override for production)
AUTH_SERVICE_URL=http://auth-service:8001
WORKFLOW_SERVICE_URL=http://workflow-service:8080
GRAPHQL_GATEWAY_URL=http://graphql-gateway:4001/graphql
BFF_URL=http://bff-server:4000
